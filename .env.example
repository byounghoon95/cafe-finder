# Docker Compose environment
# Copy this file to .env in the repository root before running:
# docker compose up -d

# PostgreSQL/PostGIS container
POSTGRES_DB=cafe_radar
POSTGRES_USER=cafe_user
POSTGRES_PASSWORD=cafe_password
POSTGRES_PORT=5432

# Spring Boot backend container, added when backend foundation is implemented
BACKEND_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/cafe_radar
SPRING_DATASOURCE_USERNAME=cafe_user
SPRING_DATASOURCE_PASSWORD=cafe_password

# React/Vite frontend container, added when frontend foundation is implemented
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080

# Google Maps JavaScript API key for the frontend map.
# Keep the real value only in .env or frontend/.env.local, never in Git.
VITE_GOOGLE_MAPS_API_KEY=
